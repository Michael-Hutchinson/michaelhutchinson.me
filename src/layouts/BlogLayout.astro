---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  date: string;
}

const { title, description, date } = Astro.props;
---

<Layout title={`${title} — Michael Hutchinson`} description={description}>
  <article class="mx-auto max-w-3xl px-6 py-24 md:py-32">
    <header class="mb-12">
      <p class="font-mono text-sm text-accent mb-3">
        <span class="font-bold" style="background: linear-gradient(135deg, var(--color-accent), var(--color-accent-2), var(--color-accent-3)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">❯</span> blog/{new Date(date).toISOString().split('T')[0]}
      </p>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-text mb-4 font-sans">
        {title}
      </h1>
      <p class="text-text-muted font-mono text-sm">
        {new Date(date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
      </p>
    </header>
    <div class="prose prose-purple max-w-none
      prose-headings:font-sans prose-headings:text-text
      prose-p:text-text-secondary prose-p:leading-relaxed
      prose-strong:text-text
      prose-li:text-text-secondary
      prose-a:text-accent prose-a:no-underline hover:prose-a:underline
      prose-code:text-accent prose-code:bg-bg-terminal prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
      prose-pre:bg-bg-terminal prose-pre:border prose-pre:border-border prose-pre:rounded-lg
      prose-h2:border-b prose-h2:border-border prose-h2:pb-2">
      <slot />
    </div>
  </article>
</Layout>
