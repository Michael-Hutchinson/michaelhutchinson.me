---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Not Found" description="Page not found">
  <section class="mx-auto max-w-4xl min-h-[80vh] flex flex-col items-center justify-center px-6 md:px-10 lg:px-12 py-20">
    <div class="bg-bg-terminal border border-border rounded-lg overflow-hidden max-w-lg w-full">
      <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-border" style="background: var(--color-bg-card);">
        <span class="w-3 h-3 rounded-full" style="background: #ff5f57;"></span>
        <span class="w-3 h-3 rounded-full" style="background: #ffbd2e;"></span>
        <span class="w-3 h-3 rounded-full" style="background: #28c840;"></span>
        <span class="text-[0.6875rem] text-text-muted mx-auto">zsh</span>
      </div>
      <div class="p-6">
        <div class="flex items-baseline gap-2.5 text-[0.9375rem] mb-3">
          <span class="font-bold text-base select-none" style="background: linear-gradient(135deg, var(--color-accent), var(--color-accent-2), var(--color-accent-3)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">❯</span>
          <span class="text-text">cd {Astro.url.pathname}</span>
        </div>
        <p class="text-[0.9375rem] mb-4 text-red-400">
          zsh: no such file or directory: {Astro.url.pathname}
        </p>
        <div class="flex items-baseline gap-2.5 text-[0.9375rem] mb-6">
          <span class="font-bold text-base select-none" style="background: linear-gradient(135deg, var(--color-accent), var(--color-accent-2), var(--color-accent-3)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">❯</span>
          <span class="text-text-muted">_</span>
        </div>
        <div class="border-t border-border pt-4 flex flex-col gap-2">
          <p class="text-sm text-text-muted">Try one of these instead:</p>
          <div class="flex flex-wrap gap-2">
            <a href="/" class="text-sm font-mono px-3 py-1.5 border border-border rounded hover:border-border-hover transition-colors" style="color: var(--color-accent);">~/home</a>
            <a href="/#about" class="text-sm font-mono px-3 py-1.5 border border-border rounded hover:border-border-hover transition-colors" style="color: var(--color-accent);">~/about</a>
            <a href="/#expertise" class="text-sm font-mono px-3 py-1.5 border border-border rounded hover:border-border-hover transition-colors" style="color: var(--color-accent);">~/expertise</a>
            <a href="/blog" class="text-sm font-mono px-3 py-1.5 border border-border rounded hover:border-border-hover transition-colors" style="color: var(--color-accent);">~/blog</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
