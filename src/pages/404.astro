---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Not Found" description="Page not found">
  <section
    class="mx-auto flex min-h-[80vh] max-w-4xl flex-col items-center justify-center px-6 py-20 md:px-10 lg:px-12"
  >
    <div class="bg-bg-terminal border-border w-full max-w-lg overflow-hidden rounded-lg border">
      <div
        class="border-border flex items-center gap-1.5 border-b px-4 py-2.5"
        style="background: var(--color-bg-card);"
      >
        <span class="h-3 w-3 rounded-full" style="background: #ff5f57;"></span>
        <span class="h-3 w-3 rounded-full" style="background: #ffbd2e;"></span>
        <span class="h-3 w-3 rounded-full" style="background: #28c840;"></span>
        <span class="text-text-muted mx-auto text-[0.6875rem]">zsh</span>
      </div>
      <div class="p-6">
        <div class="mb-3 flex items-baseline gap-2.5 text-[0.9375rem]">
          <span
            class="text-base font-bold select-none"
            style="background: linear-gradient(135deg, var(--color-accent), var(--color-accent-2), var(--color-accent-3)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
            >❯</span
          >
          <span class="text-text">cd {Astro.url.pathname}</span>
        </div>
        <p class="mb-4 text-[0.9375rem] text-red-400">
          zsh: no such file or directory: {Astro.url.pathname}
        </p>
        <div class="mb-6 flex items-baseline gap-2.5 text-[0.9375rem]">
          <span
            class="text-base font-bold select-none"
            style="background: linear-gradient(135deg, var(--color-accent), var(--color-accent-2), var(--color-accent-3)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
            >❯</span
          >
          <span class="text-text-muted">_</span>
        </div>
        <div class="border-border flex flex-col gap-2 border-t pt-4">
          <p class="text-text-muted text-sm">Try one of these instead:</p>
          <div class="flex flex-wrap gap-2">
            <a
              href="/"
              class="border-border hover:border-border-hover rounded border px-3 py-1.5 font-mono text-sm transition-colors"
              style="color: var(--color-accent);">~/home</a
            >
            <a
              href="/#about"
              class="border-border hover:border-border-hover rounded border px-3 py-1.5 font-mono text-sm transition-colors"
              style="color: var(--color-accent);">~/about</a
            >
            <a
              href="/#expertise"
              class="border-border hover:border-border-hover rounded border px-3 py-1.5 font-mono text-sm transition-colors"
              style="color: var(--color-accent);">~/expertise</a
            >
            <a
              href="/blog"
              class="border-border hover:border-border-hover rounded border px-3 py-1.5 font-mono text-sm transition-colors"
              style="color: var(--color-accent);">~/blog</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
