---
import Layout from '../layouts/Layout.astro';
import HeroTerminal from '../components/react/HeroTerminal.tsx';
import AboutSection from '../components/react/AboutSection.tsx';
import ExpertiseSection from '../components/react/ExpertiseSection.tsx';
import ImpactSection from '../components/react/ImpactSection.tsx';
import ContactSection from '../components/react/ContactSection.tsx';
---

<Layout
  title="Michael Hutchinson — Staff Engineer"
  description="Staff Engineer based in Manchester, UK. Building AI-powered engineering cultures and shipping products that matter."
>
  <!-- Hero -->
  <div class="relative min-h-screen">
    <div class="hero-mesh absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 15% 50%, rgba(177,151,252,0.1) 0%, transparent 50%), radial-gradient(ellipse at 85% 20%, rgba(218,119,242,0.08) 0%, transparent 50%), radial-gradient(ellipse at 50% 80%, rgba(255,160,122,0.05) 0%, transparent 50%);" />
    <section id="home" class="relative mx-auto max-w-4xl min-h-screen flex flex-col justify-center px-6 md:px-10 lg:px-12 py-20">
      <HeroTerminal client:load />
    </section>
  </div>

  <!-- About -->
  <section id="about" class="mx-auto max-w-4xl px-6 md:px-10 lg:px-12 py-20 md:py-28">
    <AboutSection client:visible />
  </section>

  <!-- Expertise -->
  <section id="expertise" class="mx-auto max-w-4xl px-6 md:px-10 lg:px-12 py-20 md:py-28">
    <ExpertiseSection client:visible />
  </section>

  <!-- Impact -->
  <section id="impact" class="mx-auto max-w-4xl px-6 md:px-10 lg:px-12 py-20 md:py-28">
    <ImpactSection client:visible />
  </section>

  <!-- Contact -->
  <section id="contact" class="mx-auto max-w-4xl px-6 md:px-10 lg:px-12 py-20 md:py-28">
    <ContactSection client:visible />
  </section>
</Layout>
