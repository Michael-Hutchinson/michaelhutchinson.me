---
import Layout from '../../layouts/Layout.astro';
import BlogList from '../../components/react/BlogList.tsx';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => p.data.published)
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .map((p) => ({
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    date: p.data.date,
    tags: p.data.tags,
    readingTime: Math.max(1, Math.ceil((p.body?.split(/\s+/).length || 0) / 250)),
  }));
---

<Layout
  title="Blog — Michael Hutchinson"
  description="Thoughts on AI-powered engineering, technical leadership, and building great software."
>
  <div class="mx-auto max-w-3xl px-6 py-24 md:py-32">
    <nav class="text-text-muted mb-8 flex items-center gap-1.5 font-mono text-xs">
      <a href="/" class="hover:text-text transition-colors">~</a>
      <span>/</span>
      <span class="text-text-secondary">blog</span>
    </nav>
    <h1 class="sr-only">Blog</h1>
    <div class="mb-8 flex items-baseline gap-2.5 text-[0.9375rem]">
      <span
        class="text-base font-bold select-none"
        style="background: linear-gradient(135deg, var(--color-accent), var(--color-accent-2), var(--color-accent-3)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
        >❯</span
      >
      <span class="text-text">ls ~/blog/</span>
    </div>

    <BlogList posts={posts} client:load />
  </div>
</Layout>
