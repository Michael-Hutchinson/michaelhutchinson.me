---
import Nav from './react/Nav.tsx';
---

<header
  id="site-header"
  class="fixed top-0 z-50 flex h-14 w-full items-center border-b border-transparent px-6 transition-all duration-300 md:px-10"
>
  <Nav client:load />
</header>

<script>
  const header = document.getElementById('site-header');
  window.addEventListener(
    'scroll',
    () => {
      const isLight = document.documentElement.getAttribute('data-theme') === 'light';
      if (window.scrollY > 20) {
        header?.classList.add('backdrop-blur-md');
        header!.style.backgroundColor = isLight
          ? 'rgba(250, 250, 250, 0.9)'
          : 'rgba(26, 26, 46, 0.9)';
        header!.style.borderColor = isLight ? 'rgba(0, 0, 0, 0.08)' : 'rgba(255, 255, 255, 0.06)';
      } else {
        header?.classList.remove('backdrop-blur-md');
        header!.style.backgroundColor = 'transparent';
        header!.style.borderColor = 'transparent';
      }
    },
    { passive: true },
  );
</script>
